DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Clerk (obligatorio en produccion)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/admin"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/admin"

# URL publica de la app (links en emails, OG tags, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (notificaciones por email)
RESEND_API_KEY=""
EMAIL_FROM="JF Studio <hola@jfstudio.local>"

# Cron de recordatorios (proteccion del endpoint /api/cron/reminders)
CRON_SECRET=""

# Correo directo de la duena (nueva reserva con comprobante, etc.)
ADMIN_EMAIL=""

# Comprobantes de adelanto web (S3-compatible: AWS S3, Cloudflare R2, MinIO…)
DEPOSIT_S3_BUCKET=""
DEPOSIT_S3_REGION="auto"
DEPOSIT_S3_ACCESS_KEY_ID=""
DEPOSIT_S3_SECRET_ACCESS_KEY=""
# Opcional: endpoint custom (R2 / MinIO), ej. https://<accountid>.r2.cloudflarestorage.com
DEPOSIT_S3_ENDPOINT=""
