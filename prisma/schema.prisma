generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STYLIST
  RECEPTIONIST
}

enum AppointmentStatus {
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum InventoryMovementType {
  PURCHASE
  ADJUSTMENT
  SERVICE_USAGE
}

enum DocumentType {
  DNI
  CE
  PASSPORT
}

model SalonSettings {
  id                         String   @id @default("default")
  name                       String   @default("JF Studio")
  timezone                   String   @default("America/Lima")
  currency                   String   @default("PEN")
  appointmentIntervalMinutes Int      @default(15)
  bookingLookaheadDays       Int      @default(45)
  adminPasswordHash          String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Staff {
  id                 String              @id @default(cuid())
  clerkUserId        String?             @unique
  name               String
  email              String?             @unique
  phone              String?
  role               UserRole            @default(STYLIST)
  isActive           Boolean             @default(true)
  color              String              @default("#0f766e")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  appointments       Appointment[]
  workingHours       WorkingHour[]
  timeBlocks         TimeBlock[]
  collectedPayments  Payment[]           @relation("PaymentCollector")
  inventoryMovements InventoryMovement[] @relation("InventoryMovementCreator")
}

model WorkingHour {
  id         String  @id @default(cuid())
  staffId    String
  dayOfWeek  Int
  startTime  String
  endTime    String
  breakStart String?
  breakEnd   String?
  isActive   Boolean @default(true)
  staff      Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([dayOfWeek])
}

model Client {
  id              String          @id @default(cuid())
  name            String
  phone           String?         @unique
  email           String?
  dni             String?
  documentType    DocumentType?
  source          String?
  notes           String?
  birthday        DateTime?       @db.Date
  firstVisitAt    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  appointments    Appointment[]
  birthdayBonuses BirthdayBonus[]

  @@index([birthday])
}

model Service {
  id              String               @id @default(cuid())
  name            String               @unique
  description     String?
  durationMinutes Int
  price           Decimal              @db.Decimal(10, 2)
  requiresDeposit Boolean              @default(false)
  depositAmount   Decimal?             @db.Decimal(10, 2)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  products        ServiceProduct[]
  appointmentRows AppointmentService[]
}

model Product {
  id                String              @id @default(cuid())
  name              String              @unique
  unit              String
  stock             Decimal             @default(0) @db.Decimal(12, 2)
  lowStockThreshold Decimal             @default(0) @db.Decimal(12, 2)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  serviceProducts   ServiceProduct[]
  movements         InventoryMovement[]
}

model ServiceProduct {
  id         String  @id @default(cuid())
  serviceId  String
  productId  String
  quantity   Decimal @db.Decimal(12, 2)
  isVariable Boolean @default(false)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  service    Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, productId])
}

model Appointment {
  id                 String               @id @default(cuid())
  clientId           String
  staffId            String
  startAt            DateTime
  endAt              DateTime
  status             AppointmentStatus    @default(CONFIRMED)
  notes              String?
  totalPrice         Decimal?             @db.Decimal(10, 2)
  completedAt        DateTime?
  accessToken        String               @unique @default(cuid())
  reminderSentAt     DateTime?
  depositPaid        Boolean              @default(false)
  depositAmountPen   Decimal?             @db.Decimal(10, 2)
  depositVoucherKey  String?
  depositVoucherFilename String?
  depositVoucherMime String?
  birthdayBonusId    String?              @unique
  birthdayBonus      BirthdayBonus?       @relation("AppointmentBonus", fields: [birthdayBonusId], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  client             Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  staff              Staff                @relation(fields: [staffId], references: [id], onDelete: Restrict)
  services           AppointmentService[]
  payments           Payment[]
  inventoryMovements InventoryMovement[]

  @@index([staffId, startAt, endAt])
  @@index([status, startAt])
  @@index([clientId, startAt])
}

model AppointmentService {
  id                      String      @id @default(cuid())
  appointmentId           String
  serviceId               String
  serviceNameSnapshot     String
  durationMinutesSnapshot Int
  priceSnapshot           Decimal     @db.Decimal(10, 2)
  appointment             Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service                 Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
}

model InventoryMovement {
  id               String                @id @default(cuid())
  productId        String
  appointmentId    String?
  type             InventoryMovementType
  quantity         Decimal               @db.Decimal(12, 2)
  note             String?
  createdByStaffId String?
  createdAt        DateTime              @default(now())
  appointment      Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdByStaff   Staff?                @relation("InventoryMovementCreator", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  product          Product               @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId, createdAt])
  @@index([appointmentId])
}

model Payment {
  id                 String      @id @default(cuid())
  appointmentId      String
  collectedByStaffId String?
  amount             Decimal     @db.Decimal(10, 2)
  method             String
  paidAt             DateTime    @default(now())
  note               String?
  createdAt          DateTime    @default(now())
  appointment        Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  collectedByStaff   Staff?      @relation("PaymentCollector", fields: [collectedByStaffId], references: [id], onDelete: SetNull)

  @@index([paidAt])
  @@index([method])
}

model PaymentMethodConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BirthdayBonusSettings {
  id              String   @id @default("default")
  enabled         Boolean  @default(true)
  discountPercent Int      @default(15)
  validityDays    Int      @default(30)
  messageTemplate String   @default("Feliz cumpleanos, {nombre}! En JF Studio queremos celebrarte con un {descuento}% de descuento en tu proximo servicio. Tu codigo: {codigo}. Valido hasta {vence}.")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BirthdayBonus {
  id              String       @id @default(cuid())
  clientId        String
  code            String       @unique
  discountPercent Int
  expiresAt       DateTime
  generatedAt     DateTime     @default(now())
  emailSentAt     DateTime?
  whatsappSentAt  DateTime?
  redeemedAt      DateTime?
  client          Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment     Appointment? @relation("AppointmentBonus")

  @@index([clientId, generatedAt])
  @@index([expiresAt])
}

model TimeBlock {
  id        String   @id @default(cuid())
  staffId   String?
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  staff     Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([startAt, endAt])
  @@index([staffId])
}
